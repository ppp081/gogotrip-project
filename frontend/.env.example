# คัดลอกเป็น .env ในโฟลเดอร์ frontend (หรือโฟลเดอร์ root ของ Vite app)

# ที่อยู่ API ของ Django — ต้องลงท้ายด้วย /api (ตรงกับ path ใน tripbot/urls)
VITE_BACKEND_API=http://127.0.0.1:8000/api

# Production ตัวอย่าง:
# VITE_BACKEND_API=https://tripbot-294086862024.asia-southeast1.run.app/api

# รหัสเดียวกับ ADMIN_WS_TOKEN ใน .env ของ backend (ใช้ยืนยัน WebSocket แดชบอร์ด)
VITE_WS_TOKEN=dev-ws-token-change-me
