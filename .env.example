# Copy this file to `.env` and set real values for your machine.
# Do not put production URLs, API keys, or secrets in `.env.example`.

# VITE_BACKEND_API — Base URL of the HTTP API, including the `/api` path.
# Value should describe where your backend lives, e.g.:
#   - Full URL to local backend: http://127.0.0.1:8000/api
#   - Same-origin path when a dev proxy or nginx serves /api: /api
VITE_BACKEND_API=your-backend-base-url-including-/api
