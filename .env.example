# คัดลอกเป็น .env แล้วแทนที่ทุกค่าเป็นของจริง — ห้าม commit .env
# รูปแบบ: ชื่อตัวแปร="คำอธิบายว่าใช้ทำอะไร (ไม่ใช่คีย์จริง)"

# --- Django ---
DJANGO_SECRET_KEY="สตริงลับของ Django ยาวพอสมควร (เช่น get_random_secret_key) — แยกต่อสภาพแวดล้อม"
DEBUG="True เฉพาะ dev บนเครื่อง; production / Cloud Run ใช้ False"

# --- Postgres (เช่น Supabase) ---
DB_NAME="ชื่อฐานข้อมูล มักเป็น postgres"
DB_USER="ชื่อผู้ใช้จาก Supabase (pooler หรือ direct)"
DB_PASSWORD="รหัสผ่านฐานข้อมูล"
DB_HOST="โฮสต์ เช่น aws-…pooler.supabase.com หรือ db.<ref>.supabase.co"
DB_PORT="มัก 6543 (pooler) หรือ 5432 (direct)"

# --- Frontend / CORS ---
FRONTEND_URL="origin หลายค่าคั่นด้วยจุลภาค เช่น http://localhost:5173,https://frontend.run.app"
CORS_ALLOWED_ORIGINS="ถ้าตั้ง: รายการ origin ที่เบราว์เซอร์เรียก API ได้ (คั่นด้วยจุลภาค)"

# --- URL สาธารณ์ของแบ็กเอนด์นี้ (ลิงก์สลิป, webhook บน prod) ---
PUBLIC_BACKEND_URL="URL แบบ https://… ของบริการนี้ ไม่มีท้ายสแลช"

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN="Channel access token จาก LINE Developers"
LINE_CHANNEL_SECRET="Channel secret จาก LINE Developers"
LINE_CHANNEL_NGROK_BASE="ทดสอบ webhook ในเครื่อง: https://xxxx.ngrok-free.app (ไม่ใส่ path)"

# --- AI (แชท / สรุปรีวิว) ---
OPENAI_API_KEY="คีย์ OpenAI สำหรับ LangChain และ analyze_reviews"
GOOGLE_API_KEY="คีย์ Google Generative AI ถ้าเปิดใช้ Gemini"
OPENROUTER_API_KEY="คีย์ OpenRouter ถ้าเดินผ่าน OpenRouter"
OPENROUTER_API_URL="ปกติ https://openrouter.ai/api/v1"
THAI_LLM_API_KEY="ถ้าใช้: คีย์ผู้ให้บริการ LLM ภาษาไทย"
TYPHOON_API_KEY="ถ้าใช้: คีย์ Typhoon"
TOGETHER_API_KEY="ถ้าใช้: คีย์ Together"
LITELLM_MASTER_KEY="ถ้าใช้: master key ของ LiteLLM proxy"

# --- Supabase (Storage สลิป; มักโปรเจกต์เดียวกับ Postgres) ---
SUPABASE_PASSWORD="ถ้าเครื่องมืออื่นต้องการ — แอปหลักใช้ DB_* ด้านบน"
SUPABASE_DATABASE_URL="ถ้าใช้: URL Postgres แบบเต็มสำหรับ Prisma ฯลฯ (pgbouncer=true กับ pooler)"
SUPABASE_DIRECT_URL="ถ้าใช้: URL Postgres แบบตรงสำหรับ migrate"
SUPABASE_URL="URL โปรเจกต์ https://<ref>.supabase.co"
SUPABASE_OBJECT_STORAGE="ชื่อ bucket อัปโหลด เช่น app-object-storage"
SUPABASE_SERVICE_ROLE_KEY="JWT service_role จาก Supabase — เก็บเป็นความลับ"

# --- SlipOK (ตรวจสลิป) ---
SLIPOK_API_KEY="คีย์ SlipOK (header x-authorization)"
SLIPOK_BRANCH_ID="รหัสสาขา SlipOK"
SLIPOK_BANK_CODE="รหัสธนาคาร เช่น 004"
SLIPOK_BANK_NAME="ชื่อย่อธนาคาร EN"
SLIPOK_BANK_NAME_TH="ชื่อธนาคารภาษาไทย"
SLIPOK_BANK_ACCOUNT_NUMBER="ถ้าต้องการ: เลขบัญชี"
SLIPOK_PROMPTPAY_NUMBER="เลขพร้อมเพย์ ถ้าใช้"
SLIPOK_BANK_ACCOUNT_OWNER="ชื่อเจ้าของบัญชีที่แสดงลูกค้า"
SLIPOK_LOG="ถ้าตั้ง: true/false บันทึก log SlipOK ละเอียด"
PROMPTPAY_QR_IMAGE_URL="ถ้ามี: URL รูป QR พร้อมเพย์สาธารณ์"

# --- ระบบ / realtime ---
REDIS_URL="ถ้าใช้: redis://… สำหรับ WebSocket หลาย instance; ว่างได้ (in-memory)"
BOOKING_NOTIFICATIONS_ENABLED="ถ้าตั้ง: true/false เปิดการแจ้งเตือนการจอง"
ADMIN_WS_TOKEN="โทเค็นเดียวกันกับแดชบอร์ดสำหรับยืนยัน WebSocket"
